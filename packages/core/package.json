{
  "name": "@aadarshjr123/atlas-core",
  "version": "1.0.0",
  "description": "Accessible React primitives for Atlas UI.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "package.json"
  ],
  "sideEffects": false,
  "license": "MIT",
  "keywords": [
    "react",
    "design-system",
    "ui",
    "accessibility"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/aadarshjr123/atlas-ui.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/aadarshjr123/atlas-ui#readme",
  "bugs": {
    "url": "https://github.com/aadarshjr123/atlas-ui/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --external react",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-tabs": "^1.1.12",
    "@radix-ui/react-tooltip": "^1.2.7",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.3.1"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  }
}
