{
  "name": "@atlas-ui/tokens",
  "version": "0.1.0",
  "description": "Design tokens for Atlas UI.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "package.json"
  ],
  "sideEffects": false,
  "license": "MIT",
  "keywords": [
    "design-tokens",
    "react",
    "design-system"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/atlas-ui/atlas-ui.git",
    "directory": "packages/tokens"
  },
  "homepage": "https://github.com/atlas-ui/atlas-ui#readme",
  "bugs": {
    "url": "https://github.com/atlas-ui/atlas-ui/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx"
  },
  "devDependencies": {}
}
