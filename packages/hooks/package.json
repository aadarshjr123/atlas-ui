{
  "name": "@aadarshjr123/atlas-hooks",
  "version": "1.0.0",
  "description": "React hooks for AI interaction state, streaming, traces, approvals, evaluation, and run metrics.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "package.json"
  ],
  "sideEffects": false,
  "license": "MIT",
  "keywords": [
    "react",
    "hooks",
    "ai",
    "agents",
    "streaming"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/aadarshjr123/atlas-ui.git",
    "directory": "packages/hooks"
  },
  "homepage": "https://github.com/aadarshjr123/atlas-ui#readme",
  "bugs": {
    "url": "https://github.com/aadarshjr123/atlas-ui/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --external react",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx"
  },
  "peerDependencies": {
    "react": ">=18"
  }
}
